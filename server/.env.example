NODE_ENV=development
SERVER_PORT=3000
APP_PUBLIC_URL=http://localhost:3000
TRUST_PROXY=false
DATABASE_URL=./data/dl_creator.sqlite
DATABASE_BACKUP_DIR=./backups
DATABASE_BACKUP_RETENTION_DAYS=30
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
PASSWORD_MIN_LENGTH=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_MAX=5
UPLOAD_MAX_FILE_SIZE_MB=25
UPLOAD_MAX_JSON_SIZE_MB=50
LOG_LEVEL=debug
LOG_DIR=./logs
AUDIT_RETENTION_DAYS=365
CORS_ORIGIN=http://localhost:8080
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@sdis.local
ADMIN_DISPLAY_NAME=Administrateur DL Creator
ADMIN_PASSWORD=ChangerCeMotDePasseFort123
MAIL_ENABLED=false
MAIL_DRY_RUN=true
SMTP_HOST=smtp.example.local
SMTP_PORT=587
SMTP_SECURE=false
